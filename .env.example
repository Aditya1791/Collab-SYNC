# ─────────────────────────────────────────────
# Collab-SYNC Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Node environment: "development" or "production"
NODE_ENV=development

# Port the server listens on (Railway injects this automatically)
PORT=3000

# JWT secret key — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# App URL — set this to your Railway deployment URL in production
# e.g. https://collab-sync.up.railway.app
APP_URL=http://localhost:3000
